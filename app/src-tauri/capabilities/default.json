{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "log:default",
    "updater:default",
    "process:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "/**" },
        { "path": "/**/.franke" },
        { "path": "/**/.franke/**" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/.franke" },
        { "path": "$HOME/**/.franke/**" },
        { "path": "/**/.obsidian" },
        { "path": "$HOME/**/.obsidian" },
        { "path": "**" },
        { "path": "**/.franke" },
        { "path": "**/.franke/**" },
        { "path": "**/.obsidian" }
      ]
    }
  ]
}
